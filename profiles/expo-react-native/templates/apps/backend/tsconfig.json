{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "paths": {
      "@{{PROJECT_NAME}}/shared": ["../../packages/shared/src"]
    }
  },
  "include": ["src/**/*.ts"]
}
