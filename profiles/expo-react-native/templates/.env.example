# Copy to .env and fill in. Values here are the docker-compose defaults.
DATABASE_URL=postgres://app:app@localhost:5432/{{PROJECT_NAME}}
REDIS_URL=redis://localhost:6379

# LAN-IP GOTCHA (session-start check, see state.md): the simulator/device reaches your
# backend via your Mac's LAN IP, not localhost. Update this when your network changes:
#   ipconfig getifaddr en0
EXPO_PUBLIC_API_URL=http://192.168.1.NN:3001
