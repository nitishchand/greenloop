{
  "permissions": {
    "allow": [
      "Bash(greenloop-verify:*)",
      "Bash(greenloop-doctor:*)",
      "Bash(npm test:*)",
      "Bash(npm run typecheck:*)",
      "Bash(npm start:*)",
      "Bash(npm install)",
      "Bash(maestro test:*)",
      "Bash(maestro hierarchy:*)",
      "Bash(xcrun simctl:*)",
      "Bash(docker compose up:*)",
